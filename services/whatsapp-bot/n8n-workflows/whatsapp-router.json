                "sendBody": true,
                "bodyParameters": {
                    "parameters": [
                        {
                            "name": "phone",
                            "value": "={{ $json.phone }}"
                        }
                    ]
                },
                "options": {}
            },
            "id": "rate-limit-check",
            "name": "Rate Limit Check",
            "type": "n8n-nodes-base.httpRequest",
