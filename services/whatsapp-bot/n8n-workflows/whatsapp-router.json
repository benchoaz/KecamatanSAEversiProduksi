                "path": "whatsapp-layanan",
                "responseMode": "responseNode",
                "options": {}
            },
            "id": "webhook-trigger",
            "name": "Webhook Trigger",
            "type": "n8n-nodes-base.webhook",
            "typeVersion": 1,
            "position": [
                200,
                300
            ],
            "webhookId": "whatsapp-layanan"
        },
        {
            "parameters": {
                "jsCode": "// Normalize and extract payload data\nconst payload = $input.first().json.body || $input.first().json;\n\n// Extract key fields\nconst phone = payload.from || payload.phone || payload.chatId || '';\nconst message = payload.body || payload.message || payload.text || '';\nconst fromMe = payload.fromMe || false;\nconst chatId = payload.from || payload.chatId || '';\n\n// Clean phone number\nconst cleanPhone = phone.replace(/[^0-9]/g, '');\n\n// Normalize message\nconst normalizedMessage = message.toLowerCase().trim();\n\nreturn {\n  json: {\n    phone: cleanPhone,\n    message: message,\n    normalizedMessage: normalizedMessage,\n    fromMe: fromMe,\n    chatId: chatId,\n    timestamp: Date.now(),\n    originalPayload: payload\n  }\n};"
            },
            "id": "normalize-payload",
            "name": "Normalize Payload",
            "type": "n8n-nodes-base.code",
            "typeVersion": 2,
            "position": [
                400,
                300
            ]
        },
        {
            "parameters": {
                "conditions": {
                    "boolean": [
                        {
                            "value1": "={{ $json.fromMe }}",
                            "operation": "equal",
                            "value2": false
                        }
                    ],
                    "string": [
                        {
                            "value1": "={{ $json.chatId }}",
                            "operation": "notContains",
                            "value2": "status@broadcast"
                        },
                        {
                            "value1": "={{ $json.message }}",
                            "operation": "isNotEmpty"
                        }
                    ]
                }
            },
            "id": "anti-loop-filter",
            "name": "Anti-Loop Filter",
            "type": "n8n-nodes-base.if",
            "typeVersion": 1,
            "position": [
                600,
                300
            ]
        },
        {
            "parameters": {
                "method": "POST",
