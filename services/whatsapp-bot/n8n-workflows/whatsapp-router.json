            "id": "rate-limit-passed",
            "name": "Rate Limit Passed",
            "type": "n8n-nodes-base.if",
            "typeVersion": 1,
            "position": [
                1000,
                200
            ]
        },
        {
            "parameters": {
                "jsCode": "// Intent Detection with Priority Order\nconst message = $json.normalizedMessage || '';\nconst phone = $json.phone || '';\n\n// Priority order for intent detection\nconst intents = [\n  { name: 'MENU', patterns: ['menu', 'bantuan', 'help', 'mulai', 'start', 'halo', 'hai', 'p'] },\n  { name: 'PIN_REQUEST', patterns: ['pin baru', 'pinbaru', 'lupa pin', 'reset pin', 'minta pin', 'kirim pin'] },\n  { name: 'TOGGLE', patterns: ['tutup lapak', 'buka lapak', 'tutuplapak', 'bukalapak'] },\n  { name: 'STATUS', patterns: ['status', 'cek berkas', 'nomor berkas', 'cek status', 'tracking'] },\n  { name: 'UMKM', patterns: ['umkm', 'produk', 'kerupuk', 'makanan', 'usaha', 'jual', 'beli', 'warung', 'toko'] },\n  { name: 'JASA', patterns: ['jasa', 'tukang', 'servis', 'service', 'perbaikan', 'montir', 'tukang piket'] },\n  { name: 'LOKER', patterns: ['loker', 'lowongan', 'kerja', 'pekerjaan', 'lamar', 'rekrut'] },\n  { name: 'SYARAT', patterns: ['syarat', 'ketentuan', 'prosedur', 'cara', 'bagaimana', 'aturan'] }\n];\n\nlet detectedIntent = 'UNKNOWN';\n\n// Check each intent in priority order\nfor (const intent of intents) {\n  for (const pattern of intent.patterns) {\n    if (message.includes(pattern)) {\n      detectedIntent = intent.name;\n      break;\n    }\n  }\n  if (detectedIntent !== 'UNKNOWN') break;\n}\n\n// Special handling for confirmation\nif (message === 'ya' || message === 'y') {\n  detectedIntent = 'CONFIRM';\n}\n\nif (message === 'tidak' || message === 't' || message === 'batal') {\n  detectedIntent = 'CANCEL';\n}\n\nreturn {\n  json: {\n    ...$json,\n    intent: detectedIntent,\n    confidence: detectedIntent !== 'UNKNOWN' ? 'high' : 'low'\n  }\n};"
            },
