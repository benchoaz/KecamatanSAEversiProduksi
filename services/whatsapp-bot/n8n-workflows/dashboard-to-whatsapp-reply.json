                        }
                    ]
                },
                "options": {
                    "timeout": 30000
                }
            },
            "id": "send-to-waha",
            "name": "Send to WAHA",
            "type": "n8n-nodes-base.httpRequest",
            "typeVersion": 4.1,
            "position": [
                850,
