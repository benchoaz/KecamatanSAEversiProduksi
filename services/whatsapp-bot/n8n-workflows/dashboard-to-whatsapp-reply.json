            ]
        },
        {
            "parameters": {
                "functionCode": "// Log successful send\nreturn {\n  success: true,\n  phone: $('Validate Payload').item.json.phone,\n  type: $('Validate Payload').item.json.type,\n  service_id: $('Validate Payload').item.json.service_id,\n  uuid: $('Validate Payload').item.json.uuid,\n  sent_at: new Date().toISOString(),\n  waha_response: $json\n};"
            },
