        {
            "parameters": {
                "functionCode": "// Build inbox received message\nconst data = $json.data || $json;\nconst uuid = data.uuid || data.data?.uuid || 'N/A';\n\nconst message = `✅ *Laporan Diterima*\\n\\n` +\n  `🆔 ID: \\`${uuid}\\`\\n` +\n  `📂 Kategori: ${$('Classify Category').item.json.category}\\n` +\n  `📊 Status: Menunggu Verifikasi\\n\\n` +\n  `💡 Cek status kapan saja dengan ketik: /status ${uuid}`;\n\nreturn {\n  phone: $('Classify Category').item.json.phone,\n  message: message,\n  type: 'auto_reply',\n  uuid: uuid\n};"
            },
