            "name": "Parse Unknown Command",
            "type": "n8n-nodes-base.code",
            "typeVersion": 2,
            "position": [
                1050,
                400
            ]
        },
        {
            "parameters": {
                "functionCode": "return {\n  ...$json,\n  command: 'normal',\n  phone: $json.phone\n};"
            },
            "id": "parse-normal",
            "name": "Parse Normal Message",
            "type": "n8n-nodes-base.code",
            "typeVersion": 2,
            "position": [
                1050,
                500
