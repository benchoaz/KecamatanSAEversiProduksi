            ]
        },
        {
            "parameters": {
                "jsCode": "const replyText = 'Pesan Anda akan dijadikan pengaduan resmi. Balas YA untuk melanjutkan atau TIDAK untuk membatalkan.';\n\nreturn {\n  json: {\n    phone: $('Store Pending Complaint').item.json.phone,\n    chatId: $('Store Pending Complaint').item.json.chatId,\n    reply: replyText\n  }\n};"
            },
