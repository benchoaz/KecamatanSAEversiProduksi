            "id": "default-faq-http-id",
            "name": "Query FAQ (Default)",
            "type": "n8n-nodes-base.httpRequest",
            "typeVersion": 4,
            "position": [
                1050,
                400
            ]
        },
        {
            "parameters": {
                "functionCode": "const faqData = $input.first().json;\nconst originalMessage = $json.message;\n\nlet replyMessage = '';\n\nif (faqData && faqData.answer) {\n  replyMessage = \"🔍 *Hasil Pencarian:*\\n\\n\" + faqData.answer + \"\\n\\n---\\n*Ketik /help untuk bantuan*\";\n} else {\n  replyMessage = \"❓ *Tidak ditemukan FAQ untuk \\\"\" + originalMessage + \"*\\n\\nSilakan coba kata kunci lain atau ketik /help untuk bantuan.\";\n}\n\nreturn [{\n  json: {\n    phone: $json.phone,\n    fullPhone: $json.fullPhone,\n    message: replyMessage\n  }\n}];"
            },
            "id": "faq-format-id",
            "name": "Format FAQ Response",
            "type": "n8n-nodes-base.function",
            "typeVersion": 1,
            "position": [
                1250,
                200
            ]
        },
        {
            "parameters": {
                "functionCode": "const statusData = $input.first().json;\nconst uuid = $json.message.split(' ')[1];\n\nlet replyMessage = '';\n\nif (statusData && statusData.status) {\n  replyMessage = \"📋 *Status Pengajuan:*\\n\\n• UUID: \" + uuid + \"\\n• Status: \" + statusData.status + \"\\n• Tanggal: \" + (statusData.date || 'N/A') + \"\\n\\n*Ketik /help untuk bantuan*\";\n} else {\n  replyMessage = \"❓ *Status tidak ditemukan*\\n\\nUUID yang Anda masukkan tidak valid. Silakan periksa kembali atau ketik /help untuk bantuan.\";\n}\n\nreturn [{\n  json: {\n    phone: $json.phone,\n    fullPhone: $json.fullPhone,\n    message: replyMessage\n  }\n}];"
            },
            "id": "status-format-id",
            "name": "Format Status Response",
            "type": "n8n-nodes-base.function",
            "typeVersion": 1,
            "position": [
                1250,
                300
            ]
        },
        {
            "parameters": {
                "functionCode": "const faqData = $input.first().json;\nconst originalMessage = $json.message;\n\nlet replyMessage = '';\n\nif (faqData && faqData.answer) {\n  replyMessage = \"🔍 *Hasil Pencarian:*\\n\\n\" + faqData.answer + \"\\n\\n---\\n*Ketik /help untuk bantuan*\";\n} else {\n  replyMessage = \"❓ *Tidak ditemukan informasi untuk \\\"\" + originalMessage + \"*\\n\\nSilakan:\\n1. Coba kata kunci lain\\n2. Ketik /help untuk bantuan\";\n}\n\nreturn [{\n  json: {\n    phone: $json.phone,\n    fullPhone: $json.fullPhone,\n    message: replyMessage\n  }\n}];"
            },
