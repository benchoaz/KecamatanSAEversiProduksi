{
    "name": "WhatsApp Service Bot - Improved",
    "nodes": [
        {
            "parameters": {
                "httpMethod": "POST",
                "path": "whatsapp-bot",
                "responseMode": "onReceived",
                "options": {}
            },
            "id": "webhook-id",
            "name": "WhatsApp Webhook",
            "type": "n8n-nodes-base.webhook",
            "typeVersion": 1,
            "position": [
                250,
                300
            ]
        },
        {
            "parameters": {
                "functionCode": "// Extract sender info from WAHA webhook payload\nconst payload = $json;\nconst from = payload.from || '';\nconst isGroup = from.includes('@g.us');\nconst isBroadcast = from.includes('@broadcast');\nconst isFromMe = payload.fromMe === true;\nconst hasMedia = payload.hasMedia === true;\nconst body = payload.body || '';\nconst senderName = payload.name || 'Warga';\n\n// Filter: Only process personal messages (@c.us) that are NOT from self\nif (isGroup || isBroadcast || isFromMe) {\n  return []; // Skip this message - not a personal message\n}\n\nreturn [{\n  json: {\n    phone: from.replace('@c.us', ''),\n    fullPhone: from,\n    senderName: senderName,\n    hasMedia: hasMedia,\n    body: body,\n    isMediaOnly: hasMedia && body === ''\n  }\n}];"
            },
            "id": "filter-id",
            "name": "Filter Personal Messages",
            "type": "n8n-nodes-base.function",
            "typeVersion": 1,
            "position": [
                450,
                300
            ]
        },
        {
            "parameters": {
                "functionCode": "// Check if this is a media-only message\nconst isMediaOnly = $json.isMediaOnly === true;\n\nif (isMediaOnly) {\n  // Send media handling response\n  return [{\n    json: {\n      phone: $json.phone,\n      fullPhone: $json.fullPhone,\n      message: \"🤖 Maaf, saya hanya bisa menerima pesan teks.\\n\\nKetik:\\n- /help - Tampilkan bantuan\\n- /faq {keyword} - Cari FAQ\"\n    }\n  }];\n}\n\n// Pass through for text messages\nreturn [{\n  json: {\n    phone: $json.phone,\n    fullPhone: $json.fullPhone,\n    senderName: $json.senderName,\n    message: $json.body\n  }\n}];"
            },
            "id": "media-check-id",
            "name": "Check Media vs Text",
            "type": "n8n-nodes-base.function",
            "typeVersion": 1,
            "position": [
                650,
                300
            ]
        },
        {
            "parameters": {
                "functionCode": "// Send media handling response\nconst helpText = \"🤖 Maaf, saya hanya bisa menerima pesan teks.\\n\\nKetik:\\n- /help - Tampilkan bantuan\\n- /faq {keyword} - Cari FAQ\";\n\nreturn [{\n  json: {\n    phone: $json.phone,\n    fullPhone: $json.fullPhone,\n    message: helpText\n  }\n}];"
            },
            "id": "media-response-id",
            "name": "Media Response",
            "type": "n8n-nodes-base.function",
            "typeVersion": 1,
            "position": [
                850,
                150
            ]
        },
        {
            "parameters": {
                "mode": "switch",
                "value": "={{ $json.message }}",
                "cases": {
                    "string": [
                        {
                            "operation": "equal",
                            "value": "/help"
                        },
                        {
                            "operation": "regex",
                            "value": "^/status\\s+.+"
                        },
                        {
                            "operation": "regex",
                            "value": "^/faq\\s+.+"
                        }
                    ]
                },
                "default": "other"
            },
            "id": "route-command-id",
            "name": "Route by Command",
            "type": "n8n-nodes-base.switch",
            "typeVersion": 1,
            "position": [
                850,
                300
            ]
        },
        {
            "parameters": {
                "functionCode": "const helpText = \"🔍 *Bot Pelayanan Kecamatan*\\n\\n*Perintah yang tersedia:*\\n• /help - Tampilkan pesan ini\\n• /status [uuid] - Cek status pengajuan\\n• /faq [keyword] - Cari informasi FAQ\\n\\n*Atau langsung ketik pertanyaan Anda!*\";\n\nreturn [{\n  json: {\n    phone: $json.phone,\n    fullPhone: $json.fullPhone,\n    message: helpText\n  }\n}];"
            },
            "id": "help-response-id",
            "name": "Help Response",
            "type": "n8n-nodes-base.function",
            "typeVersion": 1,
            "position": [
                1050,
                100
            ]
        },
        {
            "parameters": {
                "method": "GET",
                "url": "http://localhost:8000/api/faq/search",
                "sendHeaders": true,
                "headerParameters": {
                    "parameters": [
                        {
                            "name": "Accept",
                            "value": "application/json"
                        }
                    ]
                },
                "sendQuery": true,
                "queryParameters": {
                    "parameters": [
                        {
                            "name": "q",
                            "value": "={{ $json.message.split(' ').slice(1).join(' ') }}"
                        }
                    ]
                },
                "options": {}
            },
            "id": "faq-http-id",
            "name": "Query FAQ",
            "type": "n8n-nodes-base.httpRequest",
            "typeVersion": 4,
            "position": [
                1050,
