                "sendBody": true,
                "specifyBody": "json",
                "jsonBody": "={{ JSON.stringify({ session: 'default', chatId: $json.chatId, text: $json.replyText }) }}",
                "options": {
                    "timeout": 10000,
                    "retry": {
