                    ]
                },
                "sendBody": true,
                "specifyBody": "json",
                "jsonBody": "={{ JSON.stringify({ session: 'default', chatId: $json.chatId, text: $json.replyText }) }}",
                "options": {
                    "timeout": 10000,
                    "retry": {
                        "enabled": true,
                        "maxTries": 2
                    }
                }
            },
            "id": "node-send-pin-prompt",
            "name": "Send PIN Prompt",
            "type": "n8n-nodes-base.httpRequest",
