# WhatsApp Bot Configuration
# Add these to your .env file

# API Token for n8n to authenticate with Dashboard
WHATSAPP_API_TOKEN=your-secure-random-token-here

# Example token generation (run this in terminal):
# php -r "echo bin2hex(random_bytes(32));"

# Note: This token should be:
# 1. At least 64 characters long
# 2. Random and unpredictable
# 3. Stored securely
# 4. Different from other API tokens
# 5. Shared with n8n via environment variables

# The same token should be configured in n8n as:
# - Environment variable: WHATSAPP_API_TOKEN
# - Used in Header: Authorization: Bearer {token}
