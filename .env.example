# Root Environment Variables for SILAP
# Used by root docker-compose.yml

# --- Domains ---
DOMAIN=kecamatanbesuk.my.id
ACME_EMAIL=benchoaz@gmail.com

# --- Database ---
DB_CONNECTION=pgsql
DB_HOST=db
DB_PORT=5432
DB_DATABASE=dashboard_kecamatan
DB_USERNAME=user
DB_PASSWORD=password

# --- WhatsApp & n8n ---
WAHA_API_KEY=your_secure_waha_api_key
DASHBOARD_API_TOKEN=your_secure_app_api_token
WHATSAPP_API_TOKEN=your_secure_wa_token

# --- App Settings ---
APP_ENV=production
APP_DEBUG=false
APP_URL=https://kecamatanbesuk.my.id
