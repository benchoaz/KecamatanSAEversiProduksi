# Root Environment Variables for SILAP
# Used by root docker-compose.yml
# ⚠️  COPY ke .env lalu isi dengan nilai NYATA sebelum deploy!

# --- Domains ---
DOMAIN=kecamatanbesuk.my.id
ACME_EMAIL=admin@kecamatanbesuk.my.id

# --- Database ---
DB_CONNECTION=pgsql
DB_HOST=db
DB_PORT=5432
DB_DATABASE=dashboard_kecamatan
DB_USERNAME=kecamatan_user
DB_PASSWORD=change_this_to_secure_db_password

# --- WhatsApp (WAHA) ---
WAHA_DASHBOARD_USERNAME=admin
WAHA_DASHBOARD_PASSWORD=change_this_to_secure_waha_password
WAHA_API_KEY=change_this_to_secure_waha_api_key

# --- App & API Tokens ---
DASHBOARD_API_TOKEN=change_this_to_secure_api_token
WHATSAPP_API_TOKEN=change_this_to_secure_wa_token

# --- App Settings ---
APP_ENV=production
APP_DEBUG=false
APP_URL=https://kecamatanbesuk.my.id
